# ── ClickHouse ──────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=wazuh_ocsf
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Input mode ─────────────────────────────────────────────────────────────────────
#
# Exactly ONE input is active at a time:
#
#   file    (DEFAULT) — tail ALERTS_FILE from disk.
#                        Works out of the box on any standard Wazuh install.
#                        Full state tracking, rotation handling, restart resume.
#
#   zeromq            — subscribe to wazuh-analysisd ZeroMQ PUB socket.
#                        Zero disk I/O — alerts go memory-to-memory.
#                        ~0 ms latency vs ~100 ms file poll.
#                        Can subscribe from a REMOTE machine.
#                        No state file, no rotation handling needed.
#                        Requires zeromq_output enabled in wazuh ossec.conf:
#
#                          <global>
#                            <zeromq_output>yes</zeromq_output>
#                            <zeromq_uri>tcp://0.0.0.0:11111/</zeromq_uri>
#                          </global>
#
INPUT_MODE=file

# ZeroMQ URI to connect to (only used when INPUT_MODE=zeromq).
# Use tcp://localhost:11111 if collocated with the Wazuh manager.
# Use tcp://<manager-ip>:11111 to run the pipeline on a separate machine.
ZEROMQ_URI=tcp://localhost:11111



# ── State file (resume on restart) ───────────────────────────────────────────
# Stores the byte-offset of the last successfully flushed batch.
# On restart the pipeline seeks to this offset — no re-processing, no skipped logs.
# On log rotation while stopped: inode mismatch is detected automatically and
# reading resumes from offset 0 on the new file.
# The directory is created automatically if it doesn't exist.
STATE_FILE=state/alerts.pos

# ── First-run behaviour (CRITICAL for large existing files) ──────────────────
# When STATE_FILE does not yet exist (first time you run this service):
#
#   true  (DEFAULT) — seek to the END of alerts.json immediately.
#           A 50 GB file is NOT replayed.  Only new alerts written after this
#           start are ingested.  Safe for production deployments.
#
#   false           — start from byte 0 of alerts.json.
#           Use this ONLY when you intentionally want to backfill ClickHouse
#           with all historical alerts (e.g. fresh install with existing data).
#           With a 50 GB file this will read the whole file — plan accordingly.
#
# This setting has NO effect after the first run because the state file
# already contains the saved byte offset from the previous run.
SEEK_TO_END_ON_FIRST_RUN=true

# ── Routing ─────────────────────────────────────────────────────────────────────
# Per-agent routing (DEFAULT — no config needed):
#   Linux agents   → wazuh_ocsf.ocsf_<agent_name>   (covers /var/log/auth.log,
#                                                      syslog, auditd, etc.)
#   Windows agents → wazuh_ocsf.ocsf_<agent_name>   (covers EventChannel,
#                                                      WinEvtLog, Sysmon, etc.)
#
# SPECIAL_LOCATIONS — only needed for agentless / integration sources where
# the "location" field identifies the source type rather than a file path,
# and where logs from many different agents/IPs should land in ONE shared table.
#
# Typical candidates:
#   - AWS CloudTrail / GuardDuty  (location: "aws-cloudtrail", "aws-guardduty")
#   - Office 365                  (location: "office365")
#   - GitHub audit                (location: "github")
#   - Google Workspace            (location: "google-workspace")
#   - Network device syslog       (location: "syslog" — forwarded from
#                                  firewalls, routers, switches with no agent)
#   - Virustotal / threat intel   (location: "virustotal")
#
# Leave empty if all your sources are agent-based (most common case).
SPECIAL_LOCATIONS=

# ── Data retention ──────────────────────────────────────────────────────────────
# Optional: automatically delete rows older than N days via ClickHouse TTL.
# Comment out or leave empty to keep all data forever.
DATA_TTL_DAYS=90

# ── Ingestion tuning ────────────────────────────────────────────────────────
#
# BATCH_SIZE          — flush a per-table buffer to ClickHouse once it holds
#                       this many rows.  Larger = fewer HTTP round-trips = better
#                       throughput at high EPS.  Smaller = lower latency per row.
#
#   Guideline by EPS:
#     < 500  EPS   →  BATCH_SIZE=1000   (timer fires first most of the time)
#     500-2k EPS   →  BATCH_SIZE=5000   (default — balanced)
#     2k-10k EPS   →  BATCH_SIZE=10000
#     > 10k  EPS   →  BATCH_SIZE=25000
#
BATCH_SIZE=5000

# FLUSH_INTERVAL_SECS — also flush on this timer even when batch_size is not
#                       reached (safety net at low EPS so rows aren't stuck in
#                       memory for a long time).
#                       Default: 5 seconds
FLUSH_INTERVAL_SECS=5

# CHANNEL_CAP         — depth of the internal async queue between the reader
#                       task and the ClickHouse writer task.  Each slot is ~1 KB
#                       so the default of 50_000 ≈ 50 MB peak in-flight.
#                       When ClickHouse is slow the reader blocks here — nothing
#                       is dropped, no memory explosion.
CHANNEL_CAP=50000


